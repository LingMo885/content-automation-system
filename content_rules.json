  "quality_evaluation_rules": {
    "evaluation_dimensions": {
      "relevance": {
        "weight": 0.25,
        "criteria": ["主题相关", "关键词覆盖", "内容聚焦"],
        "scoring_rules": {
          "excellent": "完全相关，深度聚焦",
          "good": "基本相关，稍有偏离",
          "fair": "部分相关，需要调整",
          "poor": "偏离主题，需要重写"
        }
      },
      "professionalism": {
        "weight": 0.25,
        "criteria": ["术语准确", "逻辑严谨", "分析深度"],
        "scoring_rules": {
          "excellent": "专业准确，深度分析",
          "good": "基本准确，分析合理",
          "fair": "有错误，需要修正",
          "poor": "严重错误，需要重写"
        }
      },
      "readability": {
        "weight": 0.20,
        "criteria": ["语言流畅", "结构清晰", "易于理解"],
        "scoring_rules": {
          "excellent": "非常流畅，结构清晰",
          "good": "基本流畅，结构合理",
          "fair": "有些拗口，需要优化",
          "poor": "难以理解，需要重写"
        }
      },
      "attractiveness": {
        "weight": 0.20,
        "criteria": ["标题吸引", "内容有趣", "互动性强"],
        "scoring_rules": {
          "excellent": "非常吸引，互动性强",
          "good": "比较吸引，有一定互动",
          "fair": "平淡无奇，需要优化",
          "poor": "毫无吸引力，需要重写"
        }
      },
      "compliance": {
        "weight": 0.10,
        "criteria": ["平台合规", "内容安全", "无违规"],
        "scoring_rules": {
          "excellent": "完全合规，非常安全",
          "good": "基本合规，需要注意",
          "fair": "有违规风险，需要修改",
          "poor": "严重违规，不能发布"
        }
      }
    },
    
    "quality_thresholds": {
      "excellent": 90,
      "good": 80,
      "fair": 70,
      "pass": 60,
      "fail": 60
    },
    
    "auto_correction_rules": {
      "enable_auto_correction": true,
      "correction_levels": {
        "minor": "自动修正语法错误",
        "moderate": "建议内容优化",
        "major": "需要人工审核"
      },
      "correction_triggers": {
        "grammar_errors": 3,
        "readability_score": 60,
        "compliance_issues": 1
      }
    }
  },
  
